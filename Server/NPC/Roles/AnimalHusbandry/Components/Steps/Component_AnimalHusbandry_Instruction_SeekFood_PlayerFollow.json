{
  "$Comment": "Stable SeekFood flow for Animal Husbandry. Keeps attractive-item follow behavior without the vanilla GiveUp churn.",
  "Type": "Component",
  "Class": "Instruction",
  "Interface": "AnimalHusbandry.Instruction.SeekFood.PlayerFollow",
  "Parameters": {
    "AlertedRange": {
      "Value": 18,
      "Description": "Range used to keep watching/following the current target while in SeekFood."
    },
    "AttractiveItemSet": {
      "Value": [ "Tool_Feedbag" ],
      "TypeHint": "String",
      "Description": "Items that keep the NPC interested in the current target."
    },
    "FollowItemAttitudes": {
      "Value": [ "Revered", "Friendly", "Ignore" ],
      "TypeHint": "String",
      "Description": "Attitudes allowed for attractive-item follow behavior."
    },
    "FollowItemDistance": {
      "Value": [ 2, 2.5 ],
      "Description": "Desired maintain-distance range while following an attractive item."
    },
    "EatTimeout": {
      "Value": [ "PT8H", "PT12H" ],
      "Description": "Cooldown applied after feeding."
    },
    "GreetTimeout": {
      "Value": [ "PT2H", "PT12H" ],
      "Description": "Cooldown applied to greeting after feeding."
    },
    "MaxHealth": {
      "Value": 100,
      "Description": "Health value restored after feeding."
    },
    "ParticleOffset": {
      "Value": [ 0, 1, 0 ],
      "Description": "Particle offset used by shared damage-check branch."
    }
  },
  "Content": {
    "Continue": true,
    "Sensor": {
      "Type": "Any"
    },
    "Instructions": [
      {
        "Reference": "Component_Instruction_Damage_Check",
        "Modify": {
          "_ExportStates": [ "Flee.Switch", "Panic" ],
          "AlertedRange": { "Compute": "AlertedRange" }
        }
      },
      {
        "Sensor": {
          "Type": "State",
          "State": ".Ate"
        },
        "Instructions": [
          {
            "Continue": true,
            "Sensor": {
              "Type": "Target",
              "TargetSlot": "LockedTarget",
              "Range": { "Compute": "AlertedRange" },
              "Filters": [
                {
                  "Type": "LineOfSight"
                }
              ]
            },
            "HeadMotion": {
              "Type": "Watch"
            }
          },
          {
            "ActionsBlocking": true,
            "Actions": [
              {
                "Type": "SetAlarm",
                "Name": "Eat_Ready",
                "DurationRange": { "Compute": "EatTimeout" }
              },
              {
                "$Comment": "No need to greet another player after being fed.",
                "Type": "SetAlarm",
                "Name": "Greet_Ready",
                "DurationRange": { "Compute": "GreetTimeout" }
              },
              {
                "Type": "SetStat",
                "Stat": "Health",
                "Value": { "Compute": "MaxHealth" }
              },
              {
                "Type": "Timeout",
                "Delay": [ 3, 5 ]
              },
              {
                "Type": "State",
                "State": "Idle"
              }
            ]
          }
        ]
      },
      {
        "Continue": true,
        "Sensor": {
          "Type": "Target",
          "TargetSlot": "LockedTarget",
          "Range": { "Compute": "AlertedRange" }
        },
        "HeadMotion": {
          "Type": "Watch"
        }
      },
      {
        "Enabled": { "Compute": "!isEmptyStringArray(AttractiveItemSet)" },
        "$Comment": "If the target is holding a liked item, follow it.",
        "Sensor": {
          "Type": "Target",
          "TargetSlot": "LockedTarget",
          "Filters": [
            {
              "Type": "ItemInHand",
              "Items": { "Compute": "AttractiveItemSet" }
            },
            {
              "Type": "Attitude",
              "Attitudes": { "Compute": "FollowItemAttitudes" }
            }
          ]
        },
        "BodyMotion": {
          "Type": "MaintainDistance",
          "DesiredDistanceRange": { "Compute": "FollowItemDistance" },
          "RelativeForwardsSpeed": 0.3,
          "RelativeBackwardsSpeed": 0.3
        },
        "Actions": [
          {
            "Type": "PlayAnimation",
            "Slot": "Status",
            "Animation": "Curious"
          }
        ]
      },
      {
        "$Comment": "If we still have a target but item-follow conditions are no longer met, release and return to Idle.",
        "Enabled": { "Compute": "!isEmptyStringArray(AttractiveItemSet)" },
        "Sensor": {
          "Type": "And",
          "Sensors": [
            {
              "Type": "Target",
              "TargetSlot": "LockedTarget"
            },
            {
              "Type": "Not",
              "Sensor": {
                "Type": "Target",
                "TargetSlot": "LockedTarget",
                "Filters": [
                  {
                    "Type": "ItemInHand",
                    "Items": { "Compute": "AttractiveItemSet" }
                  },
                  {
                    "Type": "Attitude",
                    "Attitudes": { "Compute": "FollowItemAttitudes" }
                  }
                ]
              }
            }
          ]
        },
        "ActionsBlocking": true,
        "ActionsAtomic": true,
        "Actions": [
          {
            "Type": "ReleaseTarget",
            "TargetSlot": "LockedTarget"
          },
          {
            "Type": "State",
            "State": "Idle"
          }
        ]
      },
      {
        "Actions": [
          {
            "Type": "Timeout",
            "Delay": [ 2, 3 ],
            "Action": {
              "Type": "State",
              "State": "Idle"
            }
          }
        ]
      }
    ]
  }
}
