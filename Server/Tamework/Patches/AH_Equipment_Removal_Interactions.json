{
  "Id": "AH_Equipment_Removal_Interactions",
  "$Comment": "Adds empty-hand equipment removal after Pet. Saddle is checked before Blanket so repeated interactions remove them in that order.",
  "Targets": [
    "Server/Tamework/Interactions/AHIntLivestock.json",
    "Server/Tamework/Interactions/AHIntNeutral.json",
    "Server/Tamework/Interactions/AHIntBeast.json"
  ],
  "When": {
    "TargetExists": true
  },
  "Priority": 100,
  "Enabled": true,
  "Operations": [
    {
      "Id": "insert-owner-saddle-removal",
      "Op": "Insert",
      "Path": "/Interactions",
      "Position": "After",
      "Find": {
        "PromptHint": "server.interactionHints.pet"
      },
      "Existing": {
        "PromptHint": "server.animalhusbandry.interactions.removeSaddle"
      },
      "Value": {
        "Type": "Custom",
        "Requires": {
          "All": {
            "IsTamed": true,
            "PlayerIsOwner": true,
            "PlayerHandEmpty": true,
            "Custom": [
              {
                "Id": "tamework:attachment_exchange_available",
                "Param": "Saddle",
                "Values": [
                  "AH_Saddle=Yes"
                ]
              }
            ]
          }
        },
        "Effects": {
          "Custom": [
            {
              "Id": "tamework:exchange_attachment",
              "Param": "Saddle",
              "Values": [
                "AH_Saddle=Yes"
              ]
            }
          ]
        },
        "PromptHint": "server.animalhusbandry.interactions.removeSaddle"
      }
    },
    {
      "Id": "insert-owner-blanket-removal",
      "Op": "Insert",
      "Path": "/Interactions",
      "Position": "After",
      "Find": {
        "PromptHint": "server.animalhusbandry.interactions.removeSaddle"
      },
      "Existing": {
        "PromptHint": "server.animalhusbandry.interactions.removeBlanket"
      },
      "Value": {
        "Type": "Custom",
        "Requires": {
          "All": {
            "IsTamed": true,
            "PlayerIsOwner": true,
            "PlayerHandEmpty": true,
            "Custom": [
              {
                "Id": "tamework:attachment_exchange_available",
                "Param": "SaddleBlanket",
                "Values": [
                  "Cloth_Block_Wool_Black=Black",
                  "Cloth_Block_Wool_Blue=Blue",
                  "Cloth_Block_Wool_Blue_Light=LightBlue",
                  "Cloth_Block_Wool_Cyan=Cyan",
                  "Cloth_Block_Wool_Cyan_Light=LightCyan",
                  "Cloth_Block_Wool_Gray=Gray",
                  "Cloth_Block_Wool_Gray_Light=LightGray",
                  "Cloth_Block_Wool_Green=Green",
                  "Cloth_Block_Wool_Green_Light=LightGreen",
                  "Cloth_Block_Wool_Orange=Orange",
                  "Cloth_Block_Wool_Orange_Light=LightOrange",
                  "Cloth_Block_Wool_Pink=Pink",
                  "Cloth_Block_Wool_Pink_Light=LightPink",
                  "Cloth_Block_Wool_Purple=Purple",
                  "Cloth_Block_Wool_Purple_Light=LightPurple",
                  "Cloth_Block_Wool_Red=Red",
                  "Cloth_Block_Wool_Red_Light=LightRed",
                  "Cloth_Block_Wool_White=White",
                  "Cloth_Block_Wool_Yellow=Yellow",
                  "Cloth_Block_Wool_Yellow_Light=LightYellow"
                ]
              }
            ]
          }
        },
        "Effects": {
          "Custom": [
            {
              "Id": "tamework:exchange_attachment",
              "Param": "SaddleBlanket",
              "Values": [
                "Cloth_Block_Wool_Black=Black",
                "Cloth_Block_Wool_Blue=Blue",
                "Cloth_Block_Wool_Blue_Light=LightBlue",
                "Cloth_Block_Wool_Cyan=Cyan",
                "Cloth_Block_Wool_Cyan_Light=LightCyan",
                "Cloth_Block_Wool_Gray=Gray",
                "Cloth_Block_Wool_Gray_Light=LightGray",
                "Cloth_Block_Wool_Green=Green",
                "Cloth_Block_Wool_Green_Light=LightGreen",
                "Cloth_Block_Wool_Orange=Orange",
                "Cloth_Block_Wool_Orange_Light=LightOrange",
                "Cloth_Block_Wool_Pink=Pink",
                "Cloth_Block_Wool_Pink_Light=LightPink",
                "Cloth_Block_Wool_Purple=Purple",
                "Cloth_Block_Wool_Purple_Light=LightPurple",
                "Cloth_Block_Wool_Red=Red",
                "Cloth_Block_Wool_Red_Light=LightRed",
                "Cloth_Block_Wool_White=White",
                "Cloth_Block_Wool_Yellow=Yellow",
                "Cloth_Block_Wool_Yellow_Light=LightYellow"
              ]
            }
          ]
        },
        "PromptHint": "server.animalhusbandry.interactions.removeBlanket"
      }
    }
  ]
}
