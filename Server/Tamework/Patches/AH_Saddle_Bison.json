{
  "Id": "AH_Saddle_Bison",
  "$Comment": "Patch any loaded Bison model definitions to include saddle. TargetExists is evaluated per target.",

  "Target": "Server/Models/Livestock/Bison.json",

  "When": {
    "TargetExists": true
  },
  "Priority": 0,
  "Enabled": true,
  "Operations": [
    {
      "Id": "add-saddles-for-bison",
      "Op": "Merge",
      "Path": "/",
      "Value": {
          "RandomAttachmentSets": {
          "Saddle": {
            "None": {
              "Model": "NPC/Livestock/Bison/Models/Attachments/Saddle_Bison.blockymodel",
              "Texture": "NPC/Wildlife/Moose/Models/Empty.png",
              "Weight": 1
            },
            "Yes": {
              "Model": "NPC/Livestock/Bison/Models/Attachments/Saddle_Bison.blockymodel",
              "Texture": "NPC/Wildlife/Moose/Models/Attachments/Saddle_Leather.png",
              "Weight": 0
            }
          }
        }
      }
    }
  ]
}
