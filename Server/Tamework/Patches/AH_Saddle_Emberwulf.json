{
  "Id": "AH_Saddle_Emberwulf",
  "$Comment": "Patch any loaded Tamed_Emberwulf_Black and Tamed_Emberwulf_White model definitions to include saddle. TargetExists is evaluated per target.",

  "Target": "Server/Models/Beast/Emberwulf.json",

  "When": {
    "TargetExists": true
  },
  "Priority": 0,
  "Enabled": true,
  "Operations": [
    {
      "Id": "add-saddles-for-emberwulf",
      "Op": "Merge",
      "Path": "/",
      "Value": {
          "RandomAttachmentSets": {
          "Saddle": {
            "None": {
              "Model": "NPC/Beast/Emberwulf/Models/Attachments/Saddle_Emberwulf.blockymodel",
              "Texture": "NPC/Wildlife/Moose/Models/Empty.png",
              "Weight": 1
            },
            "Yes": {
              "Model": "NPC/Beast/Emberwulf/Models/Attachments/Saddle_Emberwulf.blockymodel",
              "Texture": "NPC/Wildlife/Moose/Models/Attachments/Saddle_Leather.png",
              "Weight": 0
            }
          }
        }
      }
    }
  ]
}
