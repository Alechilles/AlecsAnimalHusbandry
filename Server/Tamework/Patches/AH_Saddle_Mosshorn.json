{
  "Id": "AH_Saddle_Mosshorn",
  "$Comment": "Patch any loaded Mosshorn model definitions to include saddle. TargetExists is evaluated per target.",

  "Targets": [
    "Server/Models/Wildlife/Mosshorn.json",
    "Server/Models/Wildlife/Mosshorn_Plain.json"
  ],

  "When": {
    "TargetExists": true
  },
  "Priority": 0,
  "Enabled": true,
  "Operations": [
    {
      "Id": "add-saddles-for-mosshorn",
      "Op": "Merge",
      "Path": "/",
      "Value": {
          "RandomAttachmentSets": {
          "Saddle": {
            "None": {
              "Model": "NPC/Wildlife/Mosshorn/Models/Attachments/Saddle_Mosshorn.blockymodel",
              "Texture": "NPC/Wildlife/Moose/Models/Empty.png",
              "Weight": 1
            },
            "Yes": {
              "Model": "NPC/Wildlife/Mosshorn/Models/Attachments/Saddle_Mosshorn.blockymodel",
              "Texture": "NPC/Wildlife/Moose/Models/Attachments/Saddle_Leather.png",
              "Weight": 0
            }
          }
        }
      }
    }
  ]
}
