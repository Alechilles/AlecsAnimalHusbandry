{
  "Id": "AH_Saddle_Raptor_Cave",
  "$Comment": "Patch any loaded Tamed_Raptor_Cave model definitions to include saddle. TargetExists is evaluated per target.",

  "Target": "Server/Models/Beast/Raptor_Cave.json",


  "When": {
    "TargetExists": true
  },
  "Priority": 0,
  "Enabled": true,
  "Operations": [
    {
      "Id": "add-saddles-for-raptor-cave",
      "Op": "Merge",
      "Path": "/",
      "Value": {
          "RandomAttachmentSets": {
          "Saddle": {
            "None": {
              "Model": "NPC/Beast/Raptor_Cave/Models/Attachments/Saddle_Raptor_Cave.blockymodel",
              "Texture": "NPC/Wildlife/Moose/Models/Empty.png",
              "Weight": 1
            },
            "Yes": {
              "Model": "NPC/Beast/Raptor_Cave/Models/Attachments/Saddle_Raptor_Cave.blockymodel",
              "Texture": "NPC/Wildlife/Moose/Models/Attachments/Saddle_Leather.png",
              "Weight": 0
            }
          }
        }
      }
    }
  ]
}
