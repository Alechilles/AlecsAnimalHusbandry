{
  "Id": "AH_Saddle_Lobster",
  "$Comment": "Patch loaded Lobster and Scorpion model definitions with their shared pelvis-mounted saddle. TargetExists is evaluated per target.",

  "Targets": [
    "Server/Models/Swimming_Beast/Lobster.json",
    "Server/Models/Beast/Scorpion.json"
  ],

  "When": {
    "TargetExists": true
  },
  "Priority": 0,
  "Enabled": true,
  "Operations": [
    {
      "Id": "add-saddles-for-lobster",
      "Op": "Merge",
      "Path": "/",
      "Value": {
          "RandomAttachmentSets": {
          "Saddle": {
            "None": {
              "Model": "NPC/Swimming_Beast/Lobster/Models/Attachments/Saddle_Lobster.blockymodel",
              "Texture": "NPC/Wildlife/Moose/Models/Empty.png",
              "Weight": 1
            },
            "Yes": {
              "Model": "NPC/Swimming_Beast/Lobster/Models/Attachments/Saddle_Lobster.blockymodel",
              "Texture": "NPC/Wildlife/Moose/Models/Attachments/Saddle_Leather.png",
              "Weight": 0
            }
          }
        }
      }
    }
  ]
}
