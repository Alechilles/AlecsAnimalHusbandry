{
  "defaults": {
    "rendererName": "Animal Husbandry Soul Lantern curated icons",
    "iconSize": 128,
    "cameraScale": 1.0,
    "cameraRotation": [22.5, 45, 22.5],
    "cameraTranslation": [0, -13.5],
    "emptyValueToken": "none",
    "maxCombos": 10000
  },
  "notes": [
    "Entries are ordered from most-specific external attachment sets to more generic base-game attachment sets because Tamework matches authored attachment maps as subset criteria.",
    "Base-game models without RandomAttachmentSets are intentionally not listed as generation entries; they are covered by IconDefault or non-generated role icons.",
    "Source paths use APPDATA so this manifest works across normal Windows user profiles as long as the same upstream archives are installed in UserData/Mods."
  ],
  "sources": {
    "baseGame": {
      "modelsRoot": "${APPDATA}/Hytale/install/release/package/game/latest/Assets/Server/Models",
      "commonRoot": "${APPDATA}/Hytale/install/release/package/game/latest/Assets/Common"
    },
    "auresLivestock": {
      "modelsRoot": "${APPDATA}/Hytale/UserData/Mods/Aures_Livestock_13_05_2026_NO_PIG_COW_CHICKEN.zip!Server/Models",
      "commonRoots": [
        "${APPDATA}/Hytale/UserData/Mods/Aures_Livestock_13_05_2026_NO_PIG_COW_CHICKEN.zip!Common",
        "${APPDATA}/Hytale/install/release/package/game/latest/Assets/Common"
      ]
    },
    "cellysBabyAnimals": {
      "modelsRoot": "${APPDATA}/Hytale/UserData/Mods/Celly's Baby Animals v1.0.4.zip!Server/Models",
      "commonRoots": [
        "${APPDATA}/Hytale/UserData/Mods/Celly's Baby Animals v1.0.4.zip!Common",
        "${APPDATA}/Hytale/install/release/package/game/latest/Assets/Common"
      ]
    },
    "cellysWildlifeSkins": {
