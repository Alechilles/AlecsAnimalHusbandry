      "commonRoots": [
        "${APPDATA}/Hytale/UserData/Mods/Cellys Wildlife Skins v1.1.4.zip!Common",
        "${APPDATA}/Hytale/install/release/package/game/latest/Assets/Common"
      ]
    }
  },
